{
    "metadata": {
        "name": "English"
    },
    "exceptions": {
        "unknown_exception": "An unexpected exception occurred and I've already reported this to the developers. Sorry for the inconvenience."
    },
    "buttons": {
        "support": {
            "label": "Support"
        }
    },
    "commands": {
        "info": {
            "description": "Information about Shinshi at the moment",
            "embed": {
                "description": "You're on the **{shard} shard**.",
                "author": {
                    "name": "Hi, I'm"
                },
                "fields": {
                    "information": {
                        "name": "Information",
                        "value": [
                            "**Guilds:** {guilds}",
                            "**Latency:** {latency}"
                        ]
                    }
                }
            }
        },
        "user": {
            "arguments": {
                "target": {
                    "description": "User (Choice from list or provide ID)"
                }
            },
            "info": {
                "description": "Information about the user",
                "embed": {
                    "author": {
                        "name": "User"
                    },
                    "fields": {
                        "created_at": {
                            "name": "Created at"
                        },
                        "joined_at": {
                            "name": "Joined to {guild} at"
                        },
                        "roles": {
                            "name": "Roles",
                            "value": {
                                "no_roles": "None",
                                "many_roles": "{roles}... and {count} other"
                            }
                        }
                    }
                },
                "buttons": {
                    "avatar": "Avatar",
                    "banner": "Banner"
                }
            },
            "avatar": {
                "description": "User's avatar",
                "embed": {
                    "author": {
                        "name": "Avatar"
                    }
                },
                "buttons": {
                    "global": "Global",
                    "guild": "Guild"
                },
                "exceptions": {
                    "no_avatar_exception": "{user} don't have avatar"
                }
            },
            "banner": {
                "description": "User's banner",
                "embed": {
                    "author": {
                        "name": "Banner"
                    }
                },
                "exceptions": {
                    "no_banner_exception": "{user} don't have banner"
                }
            }
        },
        "say": {
            "description": "Send a message via webhook",
            "arguments": {
                "content": {
                    "description": "The content of the message"
                },
                "attachment": {
                    "description": "Attachment"
                },
                "channel": {
                    "description": "The channel to send the message to"
                }
            },
            "exceptions": {
                "insufficient_arguments": "Insufficient arguments. `content` or `attachment` must be provided.",
                "webhook_creation_exception": "Unable to create webhook. Possible reasons...\n- Shinshi don't permissions to create a webhook.\n- Internal Discord API error.",
                "webhook_execution_exception": "Failed to send the message using the webhook.\nPossibly, the webhook was not created or is inaccessible."
            }
        }
    }
}
