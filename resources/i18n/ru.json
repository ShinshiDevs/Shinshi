                },
                "exceptions": {
                    "no_user_avatar": "У этого пользователя нет аватара"
                }
            },
            "banner": {
                "description": "Баннер пользователя",
                "embed": {
                    "author": {
                        "name": "Баннер"
                    }
                },
                "exceptions": {
                    "no_user_avatar": "У этого пользователя нет баннера"
