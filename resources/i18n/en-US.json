{
    "metadata": {
        "name": "English"
    },
    "exceptions": {
        "unknown_exception": "An unexpected exception occurred and I've already reported this to the developers. Sorry for the inconvenience."
    },
    "buttons": {
        "support": {
            "label": "Support"
        },
        "open": {
            "label": "Open"
        }
    },
    "commands": {
        "info": {
            "description": "Information about Shinshi at the moment",
            "embed": {
                "description": "You're on the **{shard} shard**.",
                "author": {
                    "name": "Hi, I'm"
                },
                "fields": {
                    "information": {
                        "name": "Information",
                        "value": [
                            "**Guilds:** {guilds}",
                            "**Latency:** {latency}"
                        ]
                    }
                }
            }
        },
        "support": {
            "description": "Support"
        },
        "user": {
            "arguments": {
                "target": {
                    "description": "User (Choice from list or provide ID)"
                }
            },
            "info": {
                "description": "Information about the user",
                "embed": {
                    "author": {
                        "name": "User"
                    },
                    "fields": {
                        "created_at": {
                            "name": "Created at"
                        },
                        "joined_at": {
                            "name": "Joined to {guild} at"
                        },
                        "roles": {
                            "name": "Roles",
                            "value": {
                                "no_roles": "None",
                                "many_roles": "{roles}... and {count} other"
                            }
                        }
                    }
                }
            },
            "avatar": {
                "description": "User's avatar",
                "embed": {
                    "author": {
                        "name": "{user} avatar"
                    }
                },
                "exceptions": {
                    "no_avatar_exception": "{user} don't have avatar"
                }
            },
            "banner": {
                "description": "User's banner",
                "embed": {
                    "author": {
                        "name": "{user} banner"
                    }
                },
                "exceptions": {
                    "no_banner_exception": "{user} don't have banner"
                }
            }
        },
        "guild": {
            "info": {
                "description": "Information about current guild",
                "embed": {
                    "author": {
                        "name": "Guild"
                    },
                    "fields": {
                        "owner": {
                            "name": "Owner"
                        },
                        "created_at": {
                            "name": "Created at"
                        },
                        "you_joined_at": {
                            "name": "You joined at"
                        },
                        "members": {
                            "name": "Members"
                        },
                        "channels": {
                            "name": "Channels"
                        },
                        "roles": {
                            "name": "Roles"
                        },
                        "emojis": {
                            "name": "Emojis"
                        }
                    }
                }
            },
            "icon": {
                "description": "Guild's icon",
                "embed": {
                    "author": {
                        "name": "{guild} icon"
                    }
                },
                "exceptions": {
                    "no_icon_exception": "Current guild don't have icon!"
                }
            },
            "splash": {
                "description": "Guild's splash",
                "embed": {
                    "author": {
                        "name": "{guild} splash"
                    }
                },
                "exceptions": {
                    "no_splash_exception": "Current guild don't have splash!"
                }
            },
            "banner": {
                "description": "Guild's banner",
                "embed": {
                    "author": {
                        "name": "{guild} banner"
                    }
                },
                "exceptions": {
                    "no_banner_exception": "Current guild don't have banner!"
                }
            }
        },
        "invite": {
            "description": "Invite Shinshi",
            "buttons": {
                "no_permissions": {
                    "label": "Without permissions"
                },
                "administrator": {
                    "label": "Administrator"
                }
            }
        }
    }
}