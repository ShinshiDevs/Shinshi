{
    "version": 1,
    "disable_existing_loggers": true,
    "formatters": {
        "standard": {
            "format": "%(asctime)s %(levelname)-8s %(name)s %(message)s"
        },
        "colored": {
            "()": "colorlog.ColoredFormatter",
            "format": "%(thin)s%(asctime)s%(reset)s %(bold)s%(log_color)s%(levelname)-8s%(reset)s %(light_cyan)s%(name)s%(reset)s %(message)s",
            "reset": true,
            "log_colors": {
                "DEBUG": "purple",
                "INFO": "cyan",
                "WARNING": "yellow",
                "ERROR": "red",
                "CRITICAL": "white,bg_red"
            },
            "datefmt": "(%y-%m-%d) %H:%M:%S"
        }
    },
    "handlers": {
        "file": {
            "class": "logging.FileHandler",
            "formatter": "standard",
            "filename": "logs/last.log"
        },
        "console": {
            "class": "logging.StreamHandler",
            "formatter": "colored",
            "stream": "ext://sys.stdout"
        }
    },
    "root": {
        "handlers": [
            "file",
            "console"
        ],
        "level": "DEBUG"
    },
    "hikari.rest": {
        "handlers": [
            "console"
        ],
        "level": "DEBUG"
    }
}