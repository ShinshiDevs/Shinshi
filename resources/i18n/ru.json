                            "**Задержка:** {latency}"
                        ]
                    }
                }
            }
        },
        "user": {
            "arguments": {
                "target": {
                    "description": "Пользователь (Выберите из списка или укажите ID)"
                }
            },
            "info": {
                "description": "Информация о пользователе",
                "embed": {
                    "author": {
                        "name": "Пользователь"
                    },
                    "fields": {
